{
  "appId": "com.badran.cnc",
  "appName": "Badran CNC",
  "webDir": ".",
  "server": {
    "androidScheme": "https",
    "allowNavigation": [
      "*.supabase.co",
      "cmpiielkogwzfhurwqvn.supabase.co",
      "fonts.googleapis.com",
      "cdnjs.cloudflare.com"
    ],
    "cleartext": true
  },
  "android": {
    "allowMixedContent": true,
    "backgroundColor": "#f8fafc",
    "webContentsDebuggingEnabled": false
